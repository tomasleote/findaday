{
  "rules": {
    ".read": false,
    ".write": false,
    "groups": {
      "$groupId": {
        ".read": "auth != null",
        ".write": "auth != null && (!data.exists() || newData.exists())",
        "id": {
          ".write": "!data.exists()"
        },
        "createdAt": {
          ".write": "!data.exists()"
        },
        "adminTokenHash": {
          ".write": "!data.exists()"
        },
        "name": {
          ".validate": "newData.isString() && newData.val().length <= 100"
        },
        "description": {
          ".validate": "newData.isString() && newData.val().length <= 1000"
        },
        "eventType": {
          ".validate": "newData.isString()"
        },
        "startDate": {
          ".validate": "newData.isString()"
        },
        "endDate": {
          ".validate": "newData.isString()"
        },
        "adminEmail": {
          ".validate": "newData.isString()"
        },
        "location": {
          ".validate": "newData.hasChildren()"
        },
        "participants": {
          ".read": "auth != null",
          ".validate": "newData.numChildren() <= 150",
          "$participantId": {
            ".write": "auth != null && (!data.exists() || (data.exists() && newData.exists()) || !newData.exists())",
            "name": {
              ".validate": "newData.isString() && newData.val().length <= 100"
            },
            "email": {
              ".validate": "newData.isString() && newData.val().length <= 255"
            },
            "duration": {
              ".validate": "newData.isNumber()"
            },
            "blockType": {
              ".validate": "newData.isString()"
            },
            "availableDays": {
              ".validate": "newData.numChildren() <= 400",
              "$dayIndex": {
                ".validate": "newData.isString() && newData.val().length <= 10"
              }
            },
            "id": {
              ".validate": "newData.isString() && newData.val() === $participantId"
            },
            "createdAt": {
              ".write": "!data.exists()"
            }
          }
        },
        "poll": {
          ".read": "auth != null",
          ".write": "auth != null && (!data.exists() || newData.exists() || !newData.exists())",
          "status": {
            ".validate": "newData.isString() && (newData.val() === 'active' || newData.val() === 'closed')"
          },
          "mode": {
            ".validate": "newData.isString() && (newData.val() === 'single' || newData.val() === 'multi')"
          },
          "candidates": {
            ".write": "auth != null",
            ".validate": "newData.numChildren() <= 15",
            "$candidateId": {
              "startDate": {
                ".validate": "newData.isString()"
              },
              "endDate": {
                ".validate": "newData.isString()"
              },
              "label": {
                ".validate": "newData.isNumber()"
              }
            }
          },
          "votes": {
            ".write": "auth != null",
            "$participantId": {
              ".write": "auth != null",
              "candidateIds": {
                ".validate": "newData.hasChildren() || newData.isString()"
              },
              "votedAt": {
                ".validate": "newData.isString()"
              }
            }
          }
        }
      }
    }
  }
}